rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /workspaces/{workspaceId} {
      // Allow read if the user is a member of the workspace
      allow read: if request.auth != null && request.auth.uid in resource.data.members.keys();

      // Allow create if the user is setting themselves as the owner
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;

      // Allow update if:
      // 1. The user is already a member (can edit workspace data), OR
      // 2. The user is joining (new member entry exists for their UID) with 'assignee' role only.
      //    The invite doc verification is enforced client-side in the invite acceptance flow.
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members.keys() ||
        (
          !(request.auth.uid in resource.data.members.keys()) &&
          request.auth.uid in request.resource.data.members.keys() &&
          request.resource.data.members[request.auth.uid].role == "assignee" &&
          request.resource.data.members[request.auth.uid].uid == request.auth.uid
        )
      );

      // Allow delete only if the user is the owner
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    match /invites/{inviteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.createdBy;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.createdBy;
    }
  }
}

